---
import SectionContainer from "./SectionContainer.astro";
import FeatureCard from "./FeatureCard.astro";

const coreTeam = [
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
];

const coordinadores = [
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
	{ nickname: "Nickname", name: "Nombre y Apellido", role: "Technical Education" },
];
---

<SectionContainer id="team">
	<div class="flex flex-col gap-16">
		<!-- Core Team -->
		<div class="flex flex-col gap-10">
			<div class="flex items-center gap-4">
				<h2 class="text-4xl md:text-5xl font-bold">Core <span class="text-primary">Team</span></h2>
				<div class="h-[2px] flex-grow bg-neutral-100 hidden md:block"></div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{coreTeam.map(member => (
					<FeatureCard {...member} />
				))}
			</div>
		</div>

		<!-- Coordinadores -->
		<div class="flex flex-col gap-10">
			<div class="flex items-center gap-4">
				<h2 class="text-4xl md:text-5xl font-bold">Coordinadores</h2>
				<div class="h-[2px] flex-grow bg-neutral-100 hidden md:block"></div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{coordinadores.map(member => (
					<FeatureCard {...member} horizontal={true} />
				))}
			</div>
		</div>
	</div>
</SectionContainer>
