---
import SectionContainer from "./SectionContainer.astro";
import Button from "./Button.astro";
---

<SectionContainer id="comunidad" class="bg-white overflow-hidden pb-0 md:pb-0">
	<div class="flex flex-col items-center text-center gap-10 relative z-10">
		<div class="flex flex-col gap-6 max-w-2xl">
			<h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
				¿Listo para ser parte del <span class="text-primary italic">cambio?</span>
			</h2>
			<p class="text-lg md:text-xl text-neutral-600 font-medium">
				Únete a la comunidad más grande de constructores en Perú y empieza tu camino en Ethereum hoy mismo.
			</p>
		</div>

		<Button variant="secondary" size="lg" href="#unirse">
			Seguir a la comunidad
		</Button>

		<div class="mt-20 w-full">
			<h1 class="text-[12vw] md:text-[15vw] font-bold leading-none tracking-tighter text-black select-none opacity-[0.03] absolute bottom-0 left-1/2 -translate-x-1/2 whitespace-nowrap pointer-events-none">
				COMETHLIMA
			</h1>
			<h1 class="text-[12vw] md:text-[15vw] font-bold leading-none tracking-tighter text-black mt-20">
				ComEthLima
			</h1>
		</div>
	</div>
</SectionContainer>
