---
import Logo from "./Logo.astro";

const navLinks = [
	{ href: "/recursos", label: "Recursos" },
	{ href: "/team", label: "El team" },
	{ href: "/eventos", label: "Eventos" },
	{ href: "/puqi", label: "Puqi" },
	{ href: "/contacto", label: "Contacto" },
];
---

<header class="fixed top-0 left-0 w-full z-50 flex justify-center p-4">
	<nav class="max-w-4xl w-full bg-black/90 backdrop-blur-md text-white rounded-full px-8 py-3 flex items-center justify-between border border-white/10 shadow-lg">
		<div class="flex items-center gap-2">
			<a href="/" class="flex items-center gap-2 group">
				<Logo className="h-6 w-auto" color="white" />
			</a>
		</div>

		<!-- Desktop Menu -->
		<ul class="hidden md:flex items-center gap-6">
			{navLinks.map(link => (
				<li>
					<a href={link.href} class="text-[11px] font-bold uppercase tracking-widest hover:text-primary transition-colors">
						{link.label}
					</a>
				</li>
			))}
		</ul>

		<!-- Mobile Menu Button -->
		<button id="mobile-menu-btn" class="md:hidden p-2 text-white" aria-label="Menu">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
		</button>
	</nav>

	<!-- Mobile Menu Overlay -->
	<div id="mobile-menu" class="fixed inset-0 bg-black z-[-1] flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-500 md:hidden">
		<Logo className="h-12 w-auto mb-8" color="white" />
		<ul class="flex flex-col items-center gap-6">
			{navLinks.map(link => (
				<li>
					<a href={link.href} class="text-xl font-bold uppercase tracking-tighter hover:text-primary transition-colors">
						{link.label}
					</a>
				</li>
			))}
		</ul>
		<button id="close-menu" class="absolute top-8 right-8 text-white p-2">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
		</button>
	</div>
</header>

<script>
	const menuBtn = document.getElementById('mobile-menu-btn');
	const closeBtn = document.getElementById('close-menu');
	const mobileMenu = document.getElementById('mobile-menu');

	menuBtn?.addEventListener('click', () => {
		mobileMenu?.classList.remove('translate-x-full');
	});

	closeBtn?.addEventListener('click', () => {
		mobileMenu?.classList.add('translate-x-full');
	});
</script>
