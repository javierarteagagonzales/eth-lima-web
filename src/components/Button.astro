---
interface Props {
	href?: string;
	variant?: "primary" | "secondary" | "ghost";
	size?: "sm" | "md" | "lg";
	class?: string;
	[key: string]: any;
}

const { 
	href, 
	variant = "primary", 
	size = "md", 
	class: className,
	...rest
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center rounded-full font-bold transition-all duration-300 active:scale-95 cursor-pointer";

const variants = {
	primary: "bg-primary text-white hover:bg-primary-dark shadow-soft",
	secondary: "bg-black text-white hover:bg-neutral-800",
	ghost: "bg-transparent border-2 border-primary text-primary hover:bg-primary hover:text-white"
};

const sizes = {
	sm: "px-4 py-2 text-sm",
	md: "px-6 py-3 text-base",
	lg: "px-8 py-4 text-lg"
};

const Element = href ? "a" : "button";
---

<Element 
	href={href} 
	class:list={[baseStyles, variants[variant], sizes[size], className]}
	{...rest}
>
	<slot />
</Element>
