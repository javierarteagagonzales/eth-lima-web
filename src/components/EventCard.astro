---
interface Props {
	name: string;
	description: string;
	date: string;
	communities: string;
}

const { name, description, date, communities } = Astro.props;
---

<div class="bg-white p-6 md:p-8 rounded-[30px] md:rounded-[40px] shadow-sm border border-neutral-100 flex flex-col sm:flex-row gap-6 md:gap-10 items-center sm:items-start md:items-center group hover:shadow-xl transition-all duration-500">
	<div class="w-24 h-24 md:w-40 md:h-40 bg-neutral-200 rounded-[20px] md:rounded-[30px] overflow-hidden shrink-0">
		<div class="w-full h-full bg-gradient-to-br from-neutral-300 to-neutral-200 group-hover:from-primary/10 transition-colors"></div>
	</div>
	
	<div class="flex flex-col flex-grow gap-2 text-center sm:text-left">
		<h4 class="text-2xl md:text-3xl font-bold text-black leading-[0.9]">{name}</h4>
		<p class="text-[10px] md:text-xs font-medium text-neutral-400 leading-tight mb-2">{description}</p>
		
		<div class="flex flex-col gap-1">
			<span class="text-xl md:text-2xl font-bold text-black leading-[0.9]">{date}</span>
			<span class="text-[10px] md:text-xs font-medium text-neutral-400 uppercase tracking-widest leading-tight">{communities}</span>
		</div>
	</div>

	<button class="bg-black text-white px-6 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest hover:bg-primary transition-colors self-center shrink-0">
		Registro
	</button>
</div>
