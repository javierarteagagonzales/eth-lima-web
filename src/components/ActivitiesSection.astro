---
import SectionContainer from "./SectionContainer.astro";
import Button from "./Button.astro";
---

<SectionContainer class="bg-neutral-50 py-16 md:py-20">
	<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start max-w-6xl mx-auto">
		<!-- Info Side -->
		<div class="lg:col-span-5 flex flex-col gap-6">
			<h2 class="text-5xl md:text-6xl font-bold text-black leading-[0.9] tracking-tighter">
				Actividades
			</h2>
			<p class="text-lg md:text-xl text-neutral-500 font-medium leading-tight">
				Lorem Ipsum is simply dummy text of the printing and typesetting industry.
			</p>

			<div class="mt-8 group max-w-sm">
				<h3 class="text-xl font-bold mb-4 uppercase tracking-widest text-black leading-none">Próximo evento</h3>
				<div class="aspect-square bg-neutral-800 rounded-[40px] shadow-2xl relative overflow-hidden group-hover:scale-[1.02] transition-transform duration-500">
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/30 to-transparent"></div>
					<div class="absolute inset-0 flex items-center justify-center">
						<div class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-full"></div>
					</div>
				</div>
				<div class="mt-6 flex justify-center">
					<Button variant="secondary" size="md" class="px-10 py-3 rounded-xl">Enlace Luma</Button>
				</div>
			</div>
		</div>

		<!-- List Side -->
		<div class="lg:col-span-7 flex flex-col gap-4">
			{[1, 2, 3].map(() => (
				<div class="bg-white p-6 rounded-[30px] shadow-soft border border-neutral-100 flex gap-6 items-center group hover:shadow-xl transition-all duration-500">
					<div class="w-24 h-24 md:w-32 md:h-32 bg-neutral-200 rounded-[24px] overflow-hidden shrink-0">
						<div class="w-full h-full bg-gradient-to-br from-neutral-300 to-neutral-200 group-hover:from-primary/10 transition-colors"></div>
					</div>
					<div class="flex flex-col flex-grow gap-1">
						<h4 class="text-xl md:text-2xl font-bold text-black leading-[0.9]">Nombre del evento</h4>
						<div class="flex flex-col gap-0.5 mt-2">
							<span class="text-lg font-bold text-neutral-800 leading-none">Fecha y hora</span>
							<span class="text-[10px] font-medium text-neutral-400 uppercase tracking-widest leading-none">Modalidad del evento</span>
						</div>
					</div>
					<div class="w-8 h-8 bg-black rounded-full self-end mb-2 group-hover:bg-primary transition-colors"></div>
				</div>
			))}

			<div class="flex justify-center gap-3 mt-6">
				<div class="w-4 h-4 bg-neutral-800 rounded-full"></div>
				<div class="w-4 h-4 bg-neutral-300 rounded-full"></div>
			</div>
		</div>
	</div>
</SectionContainer>
