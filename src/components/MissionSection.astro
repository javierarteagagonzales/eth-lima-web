---
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer class="bg-neutral-100 flex flex-col items-center justify-center py-24 min-h-screen">
	<div class="max-w-4xl w-full flex flex-col gap-10 items-center text-center mx-auto">
		<h2 class="text-4xl md:text-5xl font-bold text-black leading-[0.9] underline decoration-primary decoration-8 underline-offset-8">
			Misión
		</h2>
		
		<p class="text-3xl md:text-5xl font-bold text-neutral-800 leading-[0.9] tracking-tighter">
			Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been
		</p>
		
		<div class="w-full max-w-[280px] md:max-w-xs aspect-square bg-black rounded-[30px] shadow-2xl mt-12 overflow-hidden relative">
			<div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent"></div>
			<!-- Simulation of a visual -->
			<div class="absolute inset-0 flex items-center justify-center">
				<div class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-full border border-white/20"></div>
			</div>
		</div>
	</div>
</SectionContainer>
