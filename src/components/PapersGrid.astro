---
import SectionContainer from "./SectionContainer.astro";

interface Paper {
	title: string;
	subtitle?: string;
}

interface Props {
	title: string;
	papers: Paper[];
}

const { title, papers } = Astro.props;
---

<SectionContainer class="py-24">
	<div class="max-w-6xl mx-auto flex flex-col gap-12">
		<h2 class="text-6xl md:text-8xl font-bold text-center leading-[0.85] tracking-tighter text-black">
			{title}
		</h2>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
			{papers.map((paper) => (
				<div class="bg-neutral-700 p-8 pt-12 aspect-[2/3] rounded-[30px] flex flex-col justify-between group transition-all duration-500 cursor-pointer shadow-xl hover:bg-black border border-white/5 relative overflow-hidden">
					<div class="flex flex-col gap-4">
						<h3 class="text-3xl md:text-4xl font-bold text-white leading-[0.85] tracking-tighter">
							{paper.title.split(' ').map((word, i) => (
								<span>{word}{word.length > 5 ? <br/> : ' '}</span>
							))}
						</h3>
						{paper.subtitle && (
							<span class="text-sm font-medium text-neutral-400 uppercase tracking-widest mt-4">
								{paper.subtitle}
							</span>
						)}
					</div>
					
					<!-- Detail circle at bottom right -->
					<div class="w-12 h-12 bg-black rounded-full self-end group-hover:bg-primary transition-colors flex items-center justify-center">
						<div class="w-2 h-2 bg-white rounded-full"></div>
					</div>
					
					<!-- Decorative gradient -->
					<div class="absolute inset-0 bg-gradient-to-tr from-white/5 to-transparent pointer-events-none"></div>
				</div>
			))}
		</div>
	</div>
</SectionContainer>
