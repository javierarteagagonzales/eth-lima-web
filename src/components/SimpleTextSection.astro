---
import SectionContainer from "./SectionContainer.astro";

interface Props {
	title: string;
	description: string;
	class?: string;
}

const { title, description, class: className } = Astro.props;
---

<SectionContainer class:list={["bg-neutral-100 min-h-[50vh] flex items-center justify-center text-center", className]}>
	<div class="max-w-3xl mx-auto flex flex-col gap-6">
		<h2 class="text-3xl md:text-4xl font-bold text-black leading-tight">
			{title}
		</h2>
		<p class="text-xl md:text-2xl text-neutral-600 font-medium leading-relaxed">
			{description}
		</p>
	</div>
</SectionContainer>
