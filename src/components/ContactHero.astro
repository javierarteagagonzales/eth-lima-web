---
import SectionContainer from "./SectionContainer.astro";
import ContactGrid from "./ContactGrid.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<SectionContainer class="min-h-screen pt-40 pb-24 flex items-center justify-center">
	<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center max-w-6xl mx-auto w-full">
		<!-- Left Side: Polaroid Box -->
		<div class="lg:col-span-4 flex justify-center lg:justify-start">
			<div class="w-full max-w-[320px] md:max-w-md aspect-[4/5] bg-neutral-700 p-6 rounded-[30px] shadow-2xl relative overflow-hidden group">
				<div class="w-full h-3/4 bg-neutral-200 rounded-2xl relative">
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent"></div>
				</div>
				<div class="mt-6 flex flex-col gap-2">
					<div class="w-1/2 h-4 bg-neutral-600 rounded-full"></div>
					<div class="w-1/3 h-4 bg-neutral-600/50 rounded-full"></div>
				</div>
			</div>
		</div>

		<!-- Center Side: Typography -->
		<div class="lg:col-span-4 flex flex-col items-center lg:items-start text-center lg:text-left">
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.85] tracking-tighter text-black">
				{title.split(' ').map((word, i) => (
					<span>{word}{i === 1 ? <br/> : ' '}</span>
				))}
			</h1>
		</div>
		
		<!-- Right Side: Contact Grid -->
		<div class="lg:col-span-4 w-full">
			<ContactGrid />
		</div>
	</div>
</SectionContainer>
