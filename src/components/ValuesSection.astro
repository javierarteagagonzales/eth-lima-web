---
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer class="py-16 md:py-20">
	<div class="flex flex-col gap-8 text-center max-w-5xl mx-auto">
		<h2 class="text-3xl md:text-5xl font-bold text-black tracking-tight underline decoration-primary decoration-4 underline-offset-8">
			Nuestros valores
		</h2>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
			{[1, 2, 3, 4].map(() => (
				<div class="bg-neutral-100 p-6 md:p-8 rounded-[30px] flex flex-col items-center justify-between aspect-square group hover:bg-black transition-colors duration-500">
					<h3 class="text-lg md:text-xl font-bold text-black group-hover:text-white transition-colors uppercase tracking-widest leading-none self-start">
						Valores
					</h3>
					<div class="w-10 h-10 md:w-12 md:h-12 bg-neutral-300 rounded-full self-end group-hover:bg-primary transition-colors"></div>
				</div>
			))}
		</div>
	</div>
</SectionContainer>
