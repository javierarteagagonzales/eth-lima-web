---
import SectionContainer from "./SectionContainer.astro";
import Button from "./Button.astro";
---

<SectionContainer class="bg-neutral-100 py-24 overflow-hidden">
	<div class="max-w-5xl mx-auto flex flex-col gap-12 items-center text-center">
		<div class="flex flex-col gap-4 max-w-2xl">
			<h2 class="text-6xl md:text-8xl font-bold leading-[0.85] tracking-tighter text-black">
				Brand kit
			</h2>
			<p class="text-lg md:text-2xl font-bold leading-[0.9] tracking-tighter text-black">
				Lorem Ipsum is simply dummy text of the printing and typesetting industry.
			</p>
			<div class="flex justify-center mt-4">
				<Button variant="secondary" size="md" class="px-8 py-2 text-xs rounded-xl shrink-0">Descargar</Button>
			</div>
		</div>

		<!-- Asset Mosaic - Centered and Smaller -->
		<div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch w-full max-w-4xl mx-auto">
			<div class="md:col-span-8 aspect-video bg-neutral-700 rounded-[30px] md:rounded-[40px] shadow-2xl relative overflow-hidden group">
				<div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
			</div>
			<div class="md:col-span-4 flex flex-col gap-6">
				<div class="flex-grow aspect-square bg-neutral-700 rounded-[30px] md:rounded-[40px] shadow-2xl relative overflow-hidden">
					<div class="absolute inset-0 bg-gradient-to-tr from-teal/20 to-transparent"></div>
				</div>
				<div class="flex-grow aspect-square bg-neutral-700 rounded-[30px] md:rounded-[40px] shadow-2xl relative overflow-hidden">
					<div class="absolute inset-0 bg-gradient-to-tr from-accent/20 to-transparent"></div>
				</div>
			</div>
		</div>

		<div class="flex flex-col gap-8 items-center">
			<p class="text-lg md:text-2xl font-bold leading-[0.9] tracking-tighter text-black max-w-2xl">
				Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s...
			</p>
			
			<div class="flex gap-4 md:gap-6 overflow-x-auto no-scrollbar pb-4 justify-center w-full">
				{[1, 2, 3, 4].map(() => (
					<div class="w-20 h-20 md:w-28 md:h-28 shrink-0 bg-neutral-700 rounded-full shadow-lg border border-white/5"></div>
				))}
			</div>
		</div>
	</div>
</SectionContainer>
