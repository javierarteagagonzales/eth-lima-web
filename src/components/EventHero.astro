---
import SectionContainer from "./SectionContainer.astro";
import Button from "./Button.astro";

interface Props {
	title: string;
	date: string;
	location: string;
	address: string;
}

const { title, date, location, address } = Astro.props;
const targetDate = new Date("2026-05-20T08:00:00");
---

<SectionContainer class="min-h-screen flex items-center justify-center pt-32 pb-20">
	<div class="flex flex-col gap-12 w-full max-w-7xl mx-auto">
		<div class="relative flex flex-col items-center text-center gap-8 w-full">
			<!-- Date (Absolute Left) -->
			<div class="lg:absolute lg:left-0 lg:top-1/2 lg:-translate-y-1/2 text-3xl md:text-4xl font-bold leading-[0.9] text-center lg:text-left max-w-[150px]">
				{date}
			</div>

			<!-- Main Title -->
			<h1 class="text-6xl md:text-8xl lg:text-9xl font-bold leading-[0.8] tracking-tighter max-w-4xl">
				{title}
			</h1>

			<!-- Button -->
			<Button variant="secondary" size="lg" class="px-10 py-4 text-sm font-bold uppercase tracking-widest rounded-xl">Registro para el evento</Button>

			<!-- Location (Absolute Right) -->
			<div class="lg:absolute lg:right-0 lg:bottom-0 text-center lg:text-right max-w-[250px]">
				<p class="text-2xl md:text-3xl font-bold leading-[0.9] mb-2">{location}</p>
				<p class="text-base font-medium text-neutral-500 leading-tight">{address}</p>
			</div>
		</div>

		<!-- Countdown Section -->
		<div class="mt-16 bg-neutral-200 rounded-[50px] p-8 md:p-12 flex flex-col items-center gap-8 shadow-inner w-full max-w-4xl mx-auto">
			<h3 class="text-xl md:text-2xl font-bold uppercase tracking-widest leading-[0.9]">Cuenta regresiva:</h3>
			<div class="flex gap-4 md:gap-12 text-center items-center">
				<div class="flex flex-col gap-2">
					<span class="text-5xl md:text-7xl font-bold leading-none" id="months-hero">00</span>
					<span class="text-xs font-bold uppercase tracking-widest text-neutral-500">Mes</span>
				</div>
				<span class="text-5xl md:text-7xl font-bold leading-none pb-4 md:pb-8">:</span>
				<div class="flex flex-col gap-2">
					<span class="text-5xl md:text-7xl font-bold leading-none" id="days-hero">00</span>
					<span class="text-xs font-bold uppercase tracking-widest text-neutral-500">Días</span>
				</div>
				<span class="text-5xl md:text-7xl font-bold leading-none pb-4 md:pb-8">:</span>
				<div class="flex flex-col gap-2">
					<span class="text-5xl md:text-7xl font-bold leading-none" id="hours-hero">00</span>
					<span class="text-xs font-bold uppercase tracking-widest text-neutral-500">Hora</span>
				</div>
				<span class="text-5xl md:text-7xl font-bold leading-none pb-4 md:pb-8">:</span>
				<div class="flex flex-col gap-2">
					<span class="text-5xl md:text-7xl font-bold leading-none" id="mins-hero">00</span>
					<span class="text-xs font-bold uppercase tracking-widest text-neutral-500">Min</span>
				</div>
			</div>
		</div>
	</div>
</SectionContainer>

<script define:vars={{ deadline: targetDate.toISOString() }}>
	const countDate = new Date(deadline).getTime();
	
	const updateCountdown = () => {
		const now = new Date().getTime();
		const gap = countDate - now;

		const second = 1000;
		const minute = second * 60;
		const hour = minute * 60;
		const day = hour * 24;
		const month = day * 30.44;

		const mo = Math.floor(gap / month);
		const d = Math.floor((gap % month) / day);
		const h = Math.floor((gap % day) / hour);
		const m = Math.floor((gap % hour) / minute);

		const monthsEl = document.getElementById("months-hero");
		const daysEl = document.getElementById("days-hero");
		const hoursEl = document.getElementById("hours-hero");
		const minsEl = document.getElementById("mins-hero");

		if (monthsEl) monthsEl.innerText = Math.max(0, mo).toString().padStart(2, '0');
		if (daysEl) daysEl.innerText = Math.max(0, d).toString().padStart(2, '0');
		if (hoursEl) hoursEl.innerText = Math.max(0, h).toString().padStart(2, '0');
		if (minsEl) minsEl.innerText = Math.max(0, m).toString().padStart(2, '0');
	};

	setInterval(updateCountdown, 60000);
	updateCountdown();
</script>
