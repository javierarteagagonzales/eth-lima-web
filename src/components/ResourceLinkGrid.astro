---
import SectionContainer from "./SectionContainer.astro";

interface Resource {
	title: string;
	description?: string;
}

interface Props {
	title: string;
	description?: string;
	resources: Resource[];
	variant?: "dark" | "light";
}

const { title, description, resources, variant = "dark" } = Astro.props;
---

<SectionContainer class:list={["py-24", variant === "light" && "bg-neutral-100"]}>
	<div class="max-w-6xl mx-auto flex flex-col gap-12">
		<div class="flex flex-col gap-4 max-w-3xl">
			<h2 class="text-6xl md:text-8xl font-bold leading-[0.85] tracking-tighter text-black">
				{title}
			</h2>
			{description && (
				<p class="text-xl md:text-2xl font-bold leading-[0.9] tracking-tighter text-neutral-500">
					{description}
				</p>
			)}
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
			{resources.map((item) => (
				<div class:list={[
					"p-8 aspect-square rounded-[30px] flex flex-col justify-between group transition-all duration-500 cursor-pointer shadow-sm border",
					variant === "dark" 
						? "bg-neutral-800 border-white/5 hover:bg-black" 
						: "bg-white border-neutral-100 hover:shadow-xl"
				]}>
					<div class="flex flex-col gap-2">
						<h3 class:list={[
							"text-2xl md:text-3xl font-bold leading-[0.85] tracking-tighter",
							variant === "dark" ? "text-white" : "text-black"
						]}>
							{item.title.split(' ').map((word, i) => (
								<span>{word}{i === 0 && item.title.includes(' ') ? <br/> : ' '}</span>
							))}
						</h3>
					</div>
					<div class:list={[
						"w-10 h-10 rounded-full self-end transition-colors",
						variant === "dark" ? "bg-black group-hover:bg-primary" : "bg-neutral-200 group-hover:bg-primary"
					]}></div>
				</div>
			))}
		</div>
	</div>
</SectionContainer>
