---
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer class="bg-neutral-100 flex items-center justify-center py-24 min-h-[50vh]">
	<div class="flex gap-8 md:gap-12 w-full overflow-x-auto pb-8 snap-x no-scrollbar">
		{[1, 2, 3].map(() => (
			<div class="min-w-[300px] md:min-w-[400px] aspect-[4/5] bg-white p-6 rounded-[30px] shadow-soft border border-neutral-50 snap-center group hover:shadow-xl transition-all duration-500">
				<div class="w-full h-3/4 bg-neutral-800 rounded-2xl overflow-hidden relative">
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-transparent"></div>
					<!-- Image placeholder -->
					<div class="absolute inset-0 flex items-center justify-center">
						<div class="w-12 h-12 bg-white/5 backdrop-blur-sm rounded-full"></div>
					</div>
				</div>
				<div class="mt-8 flex flex-col gap-2">
					<!-- Styling consistent with the bottom of a polaroid/card -->
					<div class="w-1/2 h-4 bg-neutral-100 rounded-full group-hover:bg-primary/5 transition-colors"></div>
					<div class="w-1/3 h-4 bg-neutral-50 rounded-full"></div>
				</div>
			</div>
		))}
	</div>
</SectionContainer>

<style>
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
